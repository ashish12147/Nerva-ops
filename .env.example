# Copy this file to .env on your laptop. Do not commit real values.

NERVA_ENV=development
NERVA_HOST=0.0.0.0
NERVA_PORT=8080
NERVA_SETTINGS_PATH=config/settings.yaml

# AI providers
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
CLAUDE_CLI_PATH=claude

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=change-this-locally
WHATSAPP_OWNER_NUMBER=

# Security
NERVA_DASHBOARD_ADMIN_PASSWORD=change-this-locally
NERVA_SECRET_KEY=change-this-locally
